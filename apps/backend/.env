# Database - UPDATE THESE VALUES WITH YOUR LOCAL POSTGRES CREDENTIALS
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/agro_market

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT - CHANGE THIS TO A SECURE RANDOM STRING
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Paystack (Payment Gateway) - Get from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# Flutterwave (Alternative Payment Gateway) - Get from https://dashboard.flutterwave.com
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key

# App Config
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
