generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum Condition {
  NEW
  USED
  REFURBISHED
}

enum Category {
  TRACTOR
  HARVESTER
  IMPLEMENT
  SPARE_PART
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum RfqStatus {
  OPEN
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(BUYER)
  firstName String?
  lastName  String?
  phone     String?
  isVerified Boolean @default(false)
  isActive   Boolean @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  profile   Profile?
  orders    Order[]
  rfqs      Rfq[]
  products  Product[]
  financingRequests FinancingRequest[]
  buyerConversations    Conversation[] @relation("BuyerConversations")
  sellerConversations   Conversation[] @relation("SellerConversations")
  messages              Message[]
  rfqQuotes            RfqQuote[]
  freightQuotes        FreightQuote[]
  warrantyClaims       WarrantyClaim[]
  supportTickets       SupportTicket[]
  supportReplies       SupportReply[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  avatar        String?
  address       String?
  city          String?
  state         String?
  country       String   @default("Nigeria")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Company {
  id                String   @id @default(uuid())
  name              String
  cacNumber         String?  @unique
  cacDocument       String?
  isVerified       Boolean  @default(false)
  verifiedAt        DateTime?
  description       String?
  logo              String?
  address           String?
  city              String?
  state             String?
  website           String?
  phone             String?
  email             String?
  users             User[]
  products          Product[]
  orders            Order[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CategoryModel {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  slug        String    @unique
  parentId    String?
  parent      CategoryModel? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    CategoryModel[] @relation("CategoryHierarchy")
  products    Product[]
  promotions  CategoryPromotion[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String     @id @default(uuid())
  title         String
  slug          String     @unique
  description   String     @db.Text
  price         Decimal    @db.Decimal(12, 2)
  condition     Condition  @default(NEW)
  horsepower    Int?
  warrantyMonths Int?
  images        String[]
  specs         Json?
  inStock       Boolean    @default(true)
  stockQuantity Int        @default(0)
  status        ProductStatus @default(PENDING)
  rejectionReason String?
  categoryId    String
  category      CategoryModel @relation(fields: [categoryId], references: [id])
  sellerId      String
  seller        User       @relation(fields: [sellerId], references: [id])
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  rfqs          Rfq[]
  orderItems    OrderItem[]
  manuals       ProductManual[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceRecords   MaintenanceRecord[]
  warrantyClaims       WarrantyClaim[]
  financingRequests    FinancingRequest[]
  conversations  Conversation[]
  featuredProducts FeaturedProduct[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([categoryId])
  @@index([sellerId])
  @@index([companyId])
  @@index([status])
}

model ProductManual {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title       String
  fileUrl     String
  fileType    String
  createdAt   DateTime @default(now())
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  buyerId       String
  buyer         User        @relation(fields: [buyerId], references: [id])
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  status        OrderStatus @default(PENDING)
  subtotal      Decimal     @db.Decimal(12, 2)
  freightCost   Decimal?    @db.Decimal(12, 2)
  total         Decimal     @db.Decimal(12, 2)
  shippingAddress String?
  shippingState String?
  notes         String?
  disputeReason String?
  disputeStatus String?     // OPEN, RESOLVED, CLOSED
  resolvedAt    DateTime?
  items         OrderItem[]
  payment      Payment?
  escrow       Escrow?
  freightQuotes FreightQuote[]
  warrantyClaims WarrantyClaim[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([buyerId])
  @@index([companyId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model Rfq {
  id            String     @id @default(uuid())
  rfqNumber     String     @unique
  buyerId       String
  buyer         User       @relation(fields: [buyerId], references: [id])
  productId     String?
  product       Product?   @relation(fields: [productId], references: [id])
  title         String
  description   String     @db.Text
  quantity      Int        @default(1)
  budget        Decimal?   @db.Decimal(12, 2)
  neededBy      DateTime?
  deliveryState String?
  deliveryCity  String?
  status        RfqStatus  @default(OPEN)
  quotes        RfqQuote[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([buyerId])
  @@index([productId])
}

model RfqQuote {
  id          String   @id @default(uuid())
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  price       Decimal  @db.Decimal(12, 2)
  freightCost Decimal? @db.Decimal(12, 2)
  notes       String?
  isAccepted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([rfqId])
  @@index([sellerId])
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("NGN")
  provider        String
  providerRef     String?
  status          String   @default("pending")
  webhookData     Json?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PlatformSettings {
  id                   String          @id @default(uuid())
  paymentProvider      PaymentProvider @default(PAYSTACK)
  paystackConfig       Json?
  flutterwaveConfig    Json?
  escrowEnabled        Boolean         @default(true)
  platformFeePercent   Float           @default(2.5)
  supportEmail         String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Escrow {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  status        String        @default("held")
  provider      String
  providerRef  String?
  releasedAt    DateTime?
  releasedTo    String?
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Conversation {
  id         String    @id @default(uuid())
  buyerId    String
  buyer      User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  sellerId   String
  seller     User      @relation("SellerConversations", fields: [sellerId], references: [id])
  productId  String?
  product    Product?  @relation(fields: [productId], references: [id])
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
}

enum FinancingType {
  LEASE
  INSTALLMENT
  LOAN
}

enum FinancingStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
}

model FinancingRequest {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  productId     String
  product       Product         @relation(fields: [productId], references: [id])
  financingType FinancingType
  amount        Decimal         @db.Decimal(12, 2)
  tenureMonths  Int
  purpose       String          @db.Text
  state         String?
  city          String?
  status        FinancingStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([productId])
}

enum VehicleType {
  LOWBED
  FLATBED
  TRUCK
  PICKUP
}

model FreightQuote {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id])
  sellerId        String
  seller          User        @relation(fields: [sellerId], references: [id])
  originState     String
  destinationState String
  vehicleType     VehicleType
  cost            Decimal     @db.Decimal(12, 2)
  estimatedDays   String?
  notes           String?
  status          String      @default("pending")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orderId])
  @@index([sellerId])
}

enum MaintenanceType {
  ROUTINE
  REPAIR
  INSPECTION
  SERVICE
}

model MaintenanceSchedule {
  id              String          @id @default(uuid())
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  title           String
  description     String          @db.Text
  maintenanceType MaintenanceType
  intervalHours   Int
  notes           String?
  records         MaintenanceRecord[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([productId])
}

model MaintenanceRecord {
  id              String            @id @default(uuid())
  productId       String
  product         Product           @relation(fields: [productId], references: [id])
  scheduleId      String?
  schedule        MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  maintenanceType MaintenanceType
  description     String            @db.Text
  performedAt     DateTime
  serviceProvider String?
  cost            Decimal?          @db.Decimal(12, 2)
  createdAt       DateTime          @default(now())

  @@index([productId])
  @@index([scheduleId])
}

model WarrantyClaim {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])
  issue       String
  description String    @db.Text
  images      String[]
  status      String    @default("pending")
  adminNotes  String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([orderId])
}

// ==================== FAQ System ====================

model FaqCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  order       Int      @default(0)
  articles    FaqArticle[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FaqArticle {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  categoryId  String
  category    FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  helpfulCount Int      @default(0)
  notHelpfulCount Int  @default(0)
  order       Int      @default(0)
  published   Boolean  @default(false)
  votes       FaqVote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}

model FaqVote {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  article   FaqArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  helpful   Boolean
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([articleId])
}

// ==================== Promotions System ====================

model DiscountCode {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENTAGE") // PERCENTAGE, FIXED
  discountValue Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal? @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int       @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FeaturedSlot {
  id          String   @id @default(uuid())
  name        String   // Daily, Weekly, Monthly
  duration    Int      @default(1) // days
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  purchases   FeaturedProduct[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeaturedProduct {
  id        String        @id @default(uuid())
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  slotId    String
  slot      FeaturedSlot  @relation(fields: [slotId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String        @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([productId])
  @@index([slotId])
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  linkText    String?
  position    String    @default("HOME") // HOME, CATEGORY, PRODUCT
  startsAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CategoryPromotion {
  id              String        @id @default(uuid())
  categoryId      String
  category         CategoryModel @relation(fields: [categoryId], references: [id])
  discountType    String        @default("PERCENTAGE")
  discountValue   Decimal       @db.Decimal(10, 2)
  startsAt        DateTime
  expiresAt       DateTime
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([categoryId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  ACCOUNT
  ORDER
  PAYMENT
  PRODUCT
  SHIPPING
  REFUND
  VERIFICATION
  TECHNICAL
  IMPORT_PRODUCTS
  OTHER
}

model SupportTicket {
  id          String        @id @default(uuid())
  ticketNumber String       @unique
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  category    TicketCategory
  subject     String
  description String        @db.Text
  status      TicketStatus  @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  replies     SupportReply[]

  @@index([userId])
  @@index([status])
  @@index([category])
}

model SupportReply {
  id          String        @id @default(uuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  message     String        @db.Text
  isAdminReply Boolean     @default(false)
  createdAt   DateTime      @default(now())

  @@index([ticketId])
  @@index([userId])
}
